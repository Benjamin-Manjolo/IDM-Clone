{
  "name": "idm-clone",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:packages": "pnpm --filter @idm/shared build && pnpm --filter @idm/downloader build && pnpm --filter @idm/scheduler build && pnpm --filter @idm/video-grabber build && pnpm --filter @idm/site-grabber build",
    "dev": "pnpm run build:packages && pnpm --filter @idm/desktop dev",
    "build": "pnpm run build:packages && pnpm --filter @idm/desktop build",
    "clean": "node scripts/clean.js",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "app-builder-bin",
      "7zip-bin"
    ]
  }
}
