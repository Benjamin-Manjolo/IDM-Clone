# IDM Clone Environment Variables

# App
NODE_ENV=development
APP_NAME=IDM Clone
APP_VERSION=1.0.0

# Download settings
DEFAULT_MAX_CONNECTIONS=8
DEFAULT_CHUNK_SIZE=1048576
DEFAULT_DOWNLOAD_DIR=~/Downloads

# Speed limiter (bytes per second, 0 = unlimited)
DEFAULT_SPEED_LIMIT=0

# Scheduler
SCHEDULER_CHECK_INTERVAL=60000

# Extension messaging
EXTENSION_PORT=9182

# Update check
UPDATE_CHECK_URL=https://your-update-server.com/releases/latest