{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/electron",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@idm/shared":       ["../../packages/shared/dist/index.d.ts"],
      "@idm/downloader":   ["../../packages/downloader/dist/index.d.ts"],
      "@idm/scheduler":    ["../../packages/scheduler/dist/index.d.ts"],
      "@idm/video-grabber":["../../packages/video-grabber/dist/index.d.ts"],
      "@idm/site-grabber": ["../../packages/site-grabber/dist/index.d.ts"]
    }
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules", "dist"]
}
