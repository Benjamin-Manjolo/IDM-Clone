"scripts": {
  "dev": "concurrently \"vite --config ../../config/vite.config.ts\" \"tsc -p tsconfig.electron.json && electron dist/electron/electron/main.js\"",
  "dev:watch": "concurrently \"vite --config ../../config/vite.config.ts\" \"tsc -p tsconfig.electron.json -w\" \"wait-on tcp:5173 && electron dist/electron/electron/main.js\"",
  "build:renderer": "vite build --config ../../config/vite.config.ts",
  "build:electron": "tsc -p tsconfig.electron.json",
  "build": "pnpm build:renderer && pnpm build:electron"
}