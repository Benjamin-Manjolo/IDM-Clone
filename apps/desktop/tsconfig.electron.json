{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/electron/electron",
    "rootDir": "./electron",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@idm/shared":       ["../../packages/shared/src/index.ts"],
      "@idm/downloader":   ["../../packages/downloader/src/index.ts"],
      "@idm/scheduler":    ["../../packages/scheduler/src/index.ts"],
      "@idm/video-grabber":["../../packages/video-grabber/src/index.ts"],
      "@idm/site-grabber": ["../../packages/site-grabber/src/index.ts"]
    }
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules", "dist"]
}
