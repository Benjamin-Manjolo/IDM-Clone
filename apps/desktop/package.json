{
  "name": "@idm/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite --config ../../config/vite.config.ts\" \"tsc -p tsconfig.electron.json && electron .\"",
    "build:renderer": "vite build --config ../../config/vite.config.ts",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "pnpm build:renderer && pnpm build:electron",
    "package": "pnpm build && electron-builder --config ../../config/electron-builder.yml",
    "preview": "vite preview --config ../../config/vite.config.ts"
  },
  "dependencies": {
    "@idm/downloader": "workspace:*",
    "@idm/scheduler": "workspace:*",
    "@idm/shared": "workspace:*",
    "@idm/site-grabber": "workspace:*",
    "@idm/video-grabber": "workspace:*",
    "electron-updater": "^6.1.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3",
    "immer": "^10.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "zustand": "^4.5.2"
  }
}